<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mis Comidas Favoritas</title>
    <style>
        /* Estilos generales y reseteo */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            color: #333;
            line-height: 1.6;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }

        header {
            background-color: #2c3e50;
            color: #ecf0f1;
            width: 100%;
            text-align: center;
            padding: 2rem 0;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        main {
            /* Diseño responsivo sin frameworks */
            width: 90%;
            max-width: 800px; 
            background: #ffffff;
            margin: 2rem auto;
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            text-align: center;
        }

        img {
            width: 100%;
            max-width: 600px;
            height: auto;
            border-radius: 8px;
            margin-bottom: 1.5rem;
            object-fit: cover;
        }

        h2 {
            color: #2980b9;
            margin-bottom: 1rem;
        }

        ol {
            text-align: left;
            display: inline-block;
            margin: 0 auto 2rem auto;
            font-size: 1.1rem;
            padding-left: 2rem;
        }

        ol li {
            margin-bottom: 0.5rem;
        }

        /* Botón con transición de color */
        .btn {
            display: inline-block;
            padding: 12px 24px;
            background-color: #27ae60;
            color: white;
            font-size: 1.1rem;
            font-weight: bold;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        /* Efecto Hover */
        .btn:hover {
            background-color: #2ecc71;
        }

        @media (max-width: 480px) {
            header h1 {
                font-size: 1.5rem;
            }
            main {
                padding: 1.5rem;
            }
            .btn {
                width: 100%;
            }
        }
    </style>
</head>
<body>

    <header>
        <h1>Mis Comidas Favoritas</h1>
    </header>

    <main>
        <img src="https://images.unsplash.com/photo-1615870237502-f2d9efefce8e?q=80&w=600&auto=format&fit=crop" alt="Plato de comida deliciosa">
        
        <h2>Top 3 de Platillos</h2>
        
        <ol>
            <li>Empanada mechada</li>
            <li>Pasticho</li>
            <li>Pabellón</li>
        </ol>

        <br>

        <button class="btn">¡Quiero comer esto!</button>
    </main>

</body>
</html>
